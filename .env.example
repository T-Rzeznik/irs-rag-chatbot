# Copy this file to `.env` and fill in your keys.
# The app also accepts these via the "API Keys" expander in the UI.

# HuggingFace — required for the sentence-transformers embedding model
HF_TOKEN=hf_your_token_here

# LangSmith — optional, used for tracing
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_TRACING=true

# Google AI Studio — required, powers the Gemini 2.0 Flash LLM
GOOGLE_API_KEY=your_google_api_key_here
